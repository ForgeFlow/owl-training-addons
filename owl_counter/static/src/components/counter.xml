<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="owl_course.Counter">
        <div>
            <div>
                <div class="row">
                    <div classs="col">
                        <button
                            class="btn btn-primary"
                            t-on-click="addCounter"
                        >New Counter</button>
                    </div>
                </div>
                <div class="row">
                    <div class="col">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Count</th>
                                    <th scope="col"/>
                                </tr>
                            </thead>
                            <tbody>
                                <tr
                                    t-foreach="state.counterList"
                                    t-as="counter"
                                    t-key="counter.id"
                                >
                                    <td>
                                        <div>
                                            <span t-esc="counter.name"/>
                                        </div>
                                    </td>
                                    <td>
                                        <div>
                                            <span t-esc="counter.count"/>
                                        </div>
                                    </td>
                                    <td>
                                        <div>
                                            <button
                                                class="btn btn-warning"
                                                t-on-click="()=>this.increment(counter)"
                                            >Increment</button>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
