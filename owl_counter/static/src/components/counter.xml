<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="owl_counter.Counter">
        <div>
            <div>
                <div class="row">
                    <div class="col">
                        <button
                            class="btn btn-primary o_counter_add_counter"
                            t-on-click="addCounter"
                        >New</button>
                    </div>
                </div>
                <div class="row">
                    <div class="col">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Count</th>
                                    <th scope="col" />
                                </tr>
                            </thead>
                            <tbody>
                                <tr
                                    t-foreach="state.counterList"
                                    t-as="counter"
                                    t-key="counter.id"
                                >
                                    <td
                                        style="vertical-align: middle;"
                                        class="o_counter_element"
                                    >
                                        <div>
                                            <input
                                                t-model="counter.name"
                                                class="form-control o_counter_element_name"
                                                t-on-change="(e)=>this.updateName(e, counter)"
                                            />
                                        </div>
                                    </td>
                                    <td>
                                        <div>
                                            <span
                                                t-esc="counter.count"
                                                class="o_counter_element_count"
                                            />
                                        </div>
                                    </td>
                                    <td style="text-align: right">
                                        <button
                                            class="btn btn-warning o_counter_element_increment"
                                            t-on-click="()=>this.increment(counter)"
                                        >Increment</button>
                                        <button
                                            class="btn btn-danger o_counter_element_delete"
                                            t-on-click="()=>this.deleteCounter(counter)"
                                        >Delete</button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
