<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_owl_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">model</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_owl_dashboard_js" model="ir.actions.client">
        <field name="name">Owl Dashboard</field>
        <field name="tag">owl_dashboard.action_dashboard_js</field>
    </record>

    <menuitem name="Dashboard App" id="menu_owl_tutorial" sequence="10">
        <menuitem
            name="Dashboard"
            id="menu_owl_dashboard"
            sequence="10"
            action="action_owl_dashboard"
        />
        <menuitem
            name="Dashboard Owl"
            id="menu_owl_dashboard_js"
            sequence="10"
            action="action_owl_dashboard_js"
        />
    </menuitem>
</odoo>
