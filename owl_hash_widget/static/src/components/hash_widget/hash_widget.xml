<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="owl_hash_widget.HashField">
        <div class="o_hash_content d-inline-flex w-100">
            <t t-if="props.readonly">
                <span class="o_field_text" t-esc="props.record.data[props.name]"/>
            </t>
            <t t-else="">
                <input
                    class="o_input"
                    t-att-id="props.id"
                    type="text"
                    t-att-placeholder="props.placeholder"
                    t-ref="input"
                />
                <a
                    t-att-title="title"
                    t-on-click.prevent.stop="onClickHashButton"
                    class="ms-3 d-inline-flex align-items-center o_field_hash_button"
                >
                    <i class="fa fa-magic"></i>
                </a>
            </t>
        </div>
    </t>

</templates>
