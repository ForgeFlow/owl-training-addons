<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="web.FormEmailField" t-inherit-mode="extension">
        <xpath expr="//input" position="attributes">
            <attribute
                name="t-attf-style"
                add="color: {{ props.colorProps }}; background-color: {{ props.bgColorProps }};"
                separator=" "
            />
        </xpath>
    </t>
</templates>
