<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="owl_view_widget_inheritance.RangeField" owl="1">
        <div>
            <label for="customRange" class="form-label">
                <span t-esc="props.record.data.expected_salary" />
                <span class="ms-1" t-esc="currency" />
            </label>
            <input
                type="range"
                class="form-range"
                id="customRange"
                min="0"
                max="10000"
                step="100"
                t-att-value="props.record.data.expected_salary"
                t-on-change="(ev) => {
                    this.props.record.update(
                        { [this.props.name]: +ev.target.value }
                    );
                }"
            />
        </div>
    </t>

</templates>
