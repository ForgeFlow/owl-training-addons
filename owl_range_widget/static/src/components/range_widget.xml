<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="owl_range_widget.RangeField">
        <div>
            <label for="rangeField" class="form-label">
                <t t-esc="props.record.data.expected_salary" />
            </label>
            <input
                type="range"
                class="form-range"
                id="rangeField"
                min="0"
                max="100000"
                step="100"
                t-att-value="props.record.data.expected_salary"
                t-on-change="(ev) => {
                    this.props.record.update(
                        { [this.props.name]: +ev.target.value }
                    );
                }"
            />
        </div>
    </t>

</templates>
