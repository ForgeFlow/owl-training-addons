<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="owl_s02_ex01.NumberCard">
        <div t-attf-class="col-lg m-0 p-0 {{ props.extraClass }}">
            <div class="text-center shadow-sm border m-2 p-4">
                <div class="h1 fw-bold my-1 number_card_value">
                    <span t-esc="props.value" />
                </div>
                <div class="h3 text-muted pt-2">
                    <span t-esc="props.title" />
                </div>
                <div class="h3 text-muted">
                    <span t-esc="props.subtitle" />
                </div>
            </div>
        </div>
    </t>

</templates>
