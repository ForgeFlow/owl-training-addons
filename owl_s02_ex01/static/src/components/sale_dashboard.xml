<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="owl_s02_ex01.SaleDashboard">
        <div class="overflow-auto h-100">
            <div class="row m-3">
                <div class="col-12">
                    <div class="row">
                        <div class="col m-0 p-0">
                            <div class="shadow-sm m-2 p-4 border">
                                <div
                                    class="d-flex align-items-center justify-content-between"
                                >
                                    <h1
                                        class="text-primary fw-bold"
                                    >Sales Dashboard</h1>
                                    <div class="d-flex mx-2">
                                        <div class="me-2 p-0 align-content-center">
                                            <span class="text-muted">Month</span>
                                        </div>
                                        <select
                                            class="form-select"
                                            t-on-change="onMonthChange"
                                        >
                                            <t
                                                t-foreach="this.monthOptions"
                                                t-as="month"
                                                t-key="month.value"
                                            >
                                                <option
                                                    t-att-value="month.value"
                                                    t-if="month.value === this.selectedMonth"
                                                    selected="1"
                                                    t-esc="month.label"
                                                />
                                                <option
                                                    t-att-value="month.value"
                                                    t-if="month.value !== this.selectedMonth"
                                                    t-esc="month.label"
                                                />
                                            </t>
                                        </select>
                                        <div class="ms-3 me-2 p-0 align-content-center">
                                            <span class="text-muted">Year</span>
                                        </div>
                                        <input
                                            type="number"
                                            class="form-control"
                                            t-on-change="onYearChange"
                                            min="2000"
                                            max="2100"
                                            step="1"
                                            t-att-value="this.selectedYear"
                                        />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row o_dashboard_cards">
                        <NumberCard
                            title="'Sale orders'"
                            subtitle="'in this month'"
                            value="this.state.SOLastMonth"
                        />
                        <NumberCard
                            title="'New customers'"
                            subtitle="'in this month'"
                            value="this.state.newCustomersLastMonth"
                        />
                    </div>
                    <div class="row">
                        <div class="col m-0 p-0">
                            <div class="shadow-sm m-2 p-4 border">
                                <div
                                    class="d-flex align-items-center justify-content-between"
                                >
                                    <h2
                                        class="text-primary fw-bold"
                                    >Sales for months on the last 12 months</h2>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <Table data="this.state.SOByMonth" />
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
