<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="owl_s02_ex01.Table">
        <div class="col m-0 p-0">
            <div class="shadow-sm m-2 p-2 border">
                <table class="table table-hover table-striped">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Sale Orders</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="props.data" t-as="row" t-key="row.month">
                            <td t-esc="row.month" />
                            <td t-esc="row.count" />
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </t>

</templates>
