<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="owl_todo_list.Selector">
        <select
            class="form-select"
            t-on-change="props.onChange"
            t-att-value="props.value"
        >
            <t t-foreach="props.options" t-as="option" t-key="option.value">
                <option
                    t-att-selected="option.value == props.value"
                    t-att-value="option.value"
                    t-att-label="option.text"
                />
            </t>
        </select>
    </t>
</templates>
