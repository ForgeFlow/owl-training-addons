<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

  <t t-name="owl_todo_list.OwlTodoList" owl="1">
        <div class="todo-list-container">
            <div class="row mx-2 mt-3">
                <div class="col-lg-6">
                    <button
                        class="btn btn-primary todo-list-create"
                        t-on-click="addTask"
                    >New</button>
                </div>
            </div>

            <div class="row m-2">
                <div class="col">
                    <table class="table table-striped table-hover border">
                        <thead>
                            <tr>
                                <th scope="col">Task</th>
                                <th scope="col">Color</th>
                                <th scope="col">Priority</th>
                                <th scope="col" />
                            </tr>
                        </thead>
                        <tbody>
                            <tr
                                t-foreach="state.taskList"
                                t-as="task"
                                t-key="task.id"
                                class="todo-item"
                            >
                                <td>
                                    <input
                                        class="form-check-input todo-item-completed"
                                        type="checkbox"
                                        t-att-id="task.id"
                                        t-att-checked="task.completed"
                                        t-on-click="(e)=>this.toggleTask(e, task)"
                                        style="margin-right: 10px;"
                                    />
                                    <a
                                        href="#"
                                        class="todo-item-name"
                                        t-on-click="()=>this.editTask(task)"
                                        t-esc="task.name"
                                    />
                                </td>
                                <td>
                                    <input
                                        type="color"
                                        class="form-control form-control-color todo-item-color"
                                        id="colorInput"
                                        t-att-value="task.color"
                                        t-on-change="(e)=>this.updateColor(e, task)"
                                    />
                                </td>
                                <td>
                                    <select
                                        class="form-select todo-item-priority"
                                        t-on-change="(e)=>this.updatePriority(e, task)"
                                    >
                                        <t
                                            t-foreach="state.priorityOptions"
                                            t-as="option"
                                            t-key="option.value"
                                        >
                                            <option
                                                t-att-selected="task.priority == option.value"
                                                t-att-value="option.value"
                                                t-att-label="option.text"
                                            />
                                        </t>
                                    </select>
                                </td>
                                <td class="text-end">
                                    <button
                                        class="btn btn-sm btn-secondary me-2 todo-item-edit"
                                        t-on-click.prevent="()=>this.editTask(task)"
                                    >Edit</button>
                                    <button
                                        class="btn btn-sm btn-danger"
                                        t-on-click.stop="()=>this.deleteTask(task)"
                                    >Delete</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </t>

</templates>
