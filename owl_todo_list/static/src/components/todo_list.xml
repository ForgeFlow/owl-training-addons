<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="owl_todo_list.OwlTodoList" owl="1">
        <div>
            <div class="todo-list-container">
                <div class="row mx-2 mt-3">
                    <div class="col-lg-6">
                        <button
                            class="btn btn-primary"
                            data-bs-toggle="modal"
                            data-bs-target="#exampleModal"
                            t-on-click="addTask"
                        >New</button>
                    </div>
                    <div class="col-lg-6">
                        <div class="input-group">
                            <input
                                type="text"
                                class="form-control"
                                placeholder="Search here..."
                                t-ref="searchInput"
                                t-on-keyup="searchTasks"
                            />
                            <button
                                class="btn btn-outline-primary"
                                t-on-click="searchTasks"
                            >Search</button>
                        </div>
                    </div>
                </div>

                <div class="row m-2">
                    <div class="col">
                        <table class="table table-striped table-hover border">
                            <thead>
                                <tr>
                                    <th scope="col">Task</th>
                                    <th scope="col">Color</th>
                                    <th scope="col">Priority</th>
                                    <th scope="col" />
                                </tr>
                            </thead>
                            <tbody>
                                <tr
                                    t-foreach="state.taskList"
                                    t-as="task"
                                    t-key="task.id"
                                >
                                    <td style="vertical-align: middle;">
                                        <div class="form-check">
                                            <input
                                                class="form-check-input"
                                                type="checkbox"
                                                t-att-id="task.id"
                                                t-att-checked="task.completed"
                                                t-on-click="(e)=>this.toggleTask(e, task)"
                                            />
                                            <label
                                                class="form-check-label"
                                                t-att-for="task.id"
                                                t-attf-class="#{task.completed and 'text-decoration-line-through'}"
                                            >
                                                <span t-esc="task.name" />
                                            </label>
                                        </div>
                                    </td>
                                    <td>
                                        <input
                                            type="color"
                                            class="form-control form-control-color"
                                            id="colorInput"
                                            t-att-value="task.color"
                                            t-on-change="(e)=>this.updateColor(e, task)"
                                        />
                                    </td>

                                    <td class="w-25">
                                        <select
                                            class="form-select"
                                            t-on-change="(e)=>this.updatePriority(e, task)"
                                        >
                                            <t
                                                t-foreach="state.priorityOptions"
                                                t-as="option"
                                                t-key="option.value"
                                            >
                                                <option
                                                    t-att-selected="task.priority == option.value"
                                                    t-att-value="option.value"
                                                    t-att-label="option.text"
                                                />
                                            </t>
                                        </select>
                                    </td>

                                    <td style="text-align: right">
                                        <button
                                            class="btn btn-success me-2"
                                            data-bs-toggle="modal"
                                            data-bs-target="#exampleModal"
                                            t-on-click="()=>this.editTask(task)"
                                        >Edit</button>
                                        <button
                                            class="btn btn-danger"
                                            t-on-click="()=>this.deleteTask(task)"
                                        >Delete</button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div
            class="modal fade"
            id="exampleModal"
            tabindex="-1"
            aria-labelledby="exampleModalLabel"
            aria-hidden="true"
        >
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h1
                            class="modal-title fs-5"
                            id="exampleModalLabel"
                        >Add New Task</h1>
                        <button
                            type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close"
                        />
                    </div>

                    <div class="modal-body">
                        <div class="mb-3 row">
                            <label
                                for="name"
                                class="col-sm-2 col-form-label"
                            >Task Name</label>
                            <div class="col-sm-10">
                                <input
                                    type="text"
                                    class="form-control"
                                    id="name"
                                    t-model="state.task.name"
                                    t-ref="nameInput"
                                />
                            </div>
                        </div>

                        <div class="mb-3 row">
                            <label
                                for="color"
                                class="col-sm-2 col-form-label"
                            >Color</label>
                            <div class="col-sm-10">
                                <input
                                    type="color"
                                    class="form-control form-control-color"
                                    id="color"
                                    t-model="state.task.color"
                                />
                            </div>
                        </div>

                        <div class="mb-3 row">
                            <label
                                for="priority"
                                class="col-sm-2 col-form-label"
                            >Priority</label>
                            <div class="col-sm-10">
                                <select
                                    class="form-select"
                                    t-model="state.task.priority"
                                >
                                    <t
                                        t-foreach="state.priorityOptions"
                                        t-as="option"
                                        t-key="option.value"
                                    >
                                        <option
                                            t-att-value="option.value"
                                            t-att-label="option.text"
                                            t-att-selected="state.task.priority == option.value"
                                        />
                                    </t>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3 row">
                            <label
                                for="completed"
                                class="col-sm-2 col-form-label"
                            >Completed</label>
                            <div class="col-sm-10">
                                <input
                                    type="checkbox"
                                    t-att-disabled="1"
                                    style="margin-top: 9px;"
                                    class="form-check-input"
                                    id="completed"
                                    t-model="state.task.completed"
                                />
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button
                            type="button"
                            class="btn btn-secondary me-2"
                            data-bs-dismiss="modal"
                            t-ref="closeModalButton"
                        >Close</button>
                        <button
                            type="button"
                            class="btn btn-primary"
                            t-on-click="saveTask"
                        >Save changes</button>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
