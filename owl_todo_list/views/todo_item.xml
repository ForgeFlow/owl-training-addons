<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="owl_todo_tree_view" model="ir.ui.view">
        <field name="name">owl.todo.tree.form.view</field>
        <field name="model">todo.item</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="color" widget="color" />
                <field name="priority" />
                <field name="completed" />
            </list>
        </field>
    </record>

    <record id="owl_todo_list_form_view" model="ir.ui.view">
        <field name="name">owl.todo.form.view</field>
        <field name="model">todo.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="color" widget="color" />
                        <field name="priority" />
                        <field name="completed" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_owl_todo_list" model="ir.actions.act_window">
        <field name="name">Todo List</field>
        <field name="res_model">todo.item</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_owl_todo_list_js" model="ir.actions.client">
        <field name="name">Owl Todo List</field>
        <field name="tag">owl_todo_list.action_todo_list_js</field>
    </record>

    <menuitem name="Todo list App" id="menu_owl_tutorial" sequence="10">
        <menuitem
            name="Todo List"
            id="menu_owl_todo_list"
            sequence="10"
            action="action_owl_todo_list"
        />
        <menuitem
            name="Todo List Owl"
            id="manu_owl_todo_list_js"
            sequence="10"
            action="action_owl_todo_list_js"
        />
    </menuitem>
</odoo>
